---
import Icon from './Icon.astro';
import { u } from '../lib/url';
import type { CollectionEntry } from 'astro:content';

interface Props {
  carrera: CollectionEntry<'carreras'>;
}
const { carrera } = Astro.props;
const { nombre, descripcionCorta, duracion, modalidad, nueva, icono } = carrera.data;

const iconMap: Record<string, Parameters<typeof Icon>[0]['name']> = {
  'chart-bar': 'chart-bar',
  'cpu-chip': 'cpu-chip',
  'code-bracket': 'code-bracket',
  'map': 'map-pin',
  'globe': 'globe',
  'newspaper': 'newspaper',
};
const iconName = iconMap[icono] ?? 'chart-bar';
---
<a
  href={u(`/carreras/${carrera.slug}`)}
  class="group flex flex-col rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-xl hover:border-accent hover:-translate-y-1"
>
  <!-- Image banner -->
  <div class="relative h-36 overflow-hidden bg-primary">
    <img
      src={u(`/img/carreras/${carrera.slug}.jpg`)}
      alt=""
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-primary/85 via-primary/50 to-transparent"></div>
    {nueva && (
      <span class="absolute top-3 right-3 rounded-full bg-accent px-2.5 py-1 text-[11px] font-bold text-primary shadow-md">
        Nueva 2026
      </span>
    )}
    <!-- Icon floating -->
    <div class="absolute -bottom-5 left-5 flex h-12 w-12 items-center justify-center rounded-xl bg-white shadow-lg text-primary group-hover:text-accent group-hover:shadow-accent/30 transition-all">
      <Icon name={iconName} class="w-6 h-6" />
    </div>
  </div>
  <!-- Content -->
  <div class="flex flex-col gap-3 p-5 pt-8 flex-1">
    <h3 class="text-base font-semibold leading-snug text-slate-900 group-hover:text-primary transition-colors">
      {nombre}
    </h3>
    <p class="text-sm text-slate-500 leading-relaxed flex-1">{descripcionCorta}</p>
    <div class="flex items-center gap-3 text-xs text-slate-400 pt-2 border-t border-slate-100">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
        </svg>
        {duracion}
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 9v7.5"/>
        </svg>
        {modalidad}
      </span>
    </div>
  </div>
</a>
