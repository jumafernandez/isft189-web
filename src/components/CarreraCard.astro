---
import Icon from './Icon.astro';
import { u } from '../lib/url';
import type { CollectionEntry } from 'astro:content';

interface Props {
  carrera: CollectionEntry<'carreras'>;
}
const { carrera } = Astro.props;
const { nombre, descripcionCorta, duracion, modalidad, nueva, icono } = carrera.data;

const iconMap: Record<string, Parameters<typeof Icon>[0]['name']> = {
  'chart-bar': 'chart-bar',
  'cpu-chip': 'cpu-chip',
  'code-bracket': 'code-bracket',
  'map': 'map-pin',
  'globe': 'globe',
  'newspaper': 'newspaper',
};
const iconName = iconMap[icono] ?? 'chart-bar';
---
<a
  href={u(`/carreras/${carrera.slug}`)}
  class="group flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md hover:border-accent hover:-translate-y-0.5"
>
  <div class="flex items-start justify-between">
    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-accent/10 group-hover:text-accent transition-colors">
      <Icon name={iconName} class="w-6 h-6" />
    </div>
    {nueva && (
      <span class="rounded-full bg-accent/15 px-2.5 py-0.5 text-xs font-semibold text-accent-dark">
        Nueva 2026
      </span>
    )}
  </div>
  <div class="flex flex-col gap-1 flex-1">
    <h3 class="text-base font-semibold leading-snug text-slate-900 group-hover:text-primary transition-colors">
      {nombre}
    </h3>
    <p class="text-sm text-slate-500 leading-relaxed">{descripcionCorta}</p>
  </div>
  <div class="flex items-center gap-3 text-xs text-slate-400">
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
      </svg>
      {duracion}
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 9v7.5"/>
      </svg>
      {modalidad}
    </span>
  </div>
</a>
