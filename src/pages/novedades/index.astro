---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { u } from '../../lib/url';

const novedades = (await getCollection('novedades')).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);
---
<BaseLayout title="Novedades" description="Últimas noticias e información del ISFT N°189 de Luján.">
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <h1 class="text-4xl font-bold mb-3">Novedades</h1>
      <p class="text-slate-300">Enterate de las últimas noticias del instituto.</p>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="flex flex-col gap-6">
      {novedades.map(novedad => (
        <a
          href={u(`/novedades/${novedad.slug}`)}
          class="group flex flex-col gap-3 rounded-2xl border border-slate-200 bg-white p-6 hover:border-accent hover:shadow-md transition"
        >
          <time class="text-xs font-medium text-slate-400" datetime={novedad.data.fecha.toISOString()}>
            {novedad.data.fecha.toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2 class="text-xl font-semibold text-slate-900 group-hover:text-primary transition-colors leading-snug">
            {novedad.data.titulo}
          </h2>
          <p class="text-slate-500 leading-relaxed">{novedad.data.resumen}</p>
          <span class="text-sm font-medium text-accent mt-1">Leer más →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
