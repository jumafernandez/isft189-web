---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CarreraCard from '../../components/CarreraCard.astro';
import { getCollection } from 'astro:content';

const carreras = (await getCollection('carreras')).sort((a, b) => a.data.orden - b.data.orden);
---
<BaseLayout
  title="Carreras"
  description="Conocé las 6 tecnicaturas superiores del ISFT N°189 de Luján: Ciencia de Datos e IA, Análisis de Sistemas, Desarrollo de Software, Guía de Turismo, Turismo y Periodismo."
>
  <!-- Page header -->
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent mb-2">Oferta académica</p>
      <h1 class="text-4xl font-bold mb-3">Nuestras tecnicaturas</h1>
      <p class="text-slate-300 max-w-2xl">
        Seis tecnicaturas superiores de 3 años con título oficial y modalidad semi-presencial.
        Formación práctica y actualizada con salida laboral inmediata.
      </p>
    </div>
  </div>

  <!-- Cards -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {carreras.map(carrera => <CarreraCard carrera={carrera} />)}
    </div>

    <!-- Info strip -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 rounded-2xl bg-slate-100 p-6 text-center">
      <div>
        <p class="text-3xl font-bold text-primary">6</p>
        <p class="text-sm text-slate-500 mt-1">tecnicaturas superiores</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-primary">3 años</p>
        <p class="text-sm text-slate-500 mt-1">duración con título oficial</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-primary">Semi-pres.</p>
        <p class="text-sm text-slate-500 mt-1">modalidad flexible 2026</p>
      </div>
    </div>
  </div>
</BaseLayout>
