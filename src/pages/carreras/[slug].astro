---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import { u } from '../../lib/url';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const carreras = await getCollection('carreras');
  return carreras.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'carreras'> };
const { entry } = Astro.props;
const { Content } = await render(entry);
const { nombre, descripcionCorta, duracion, modalidad, nueva, planPdf, icono } = entry.data;

const iconMap: Record<string, Parameters<typeof Icon>[0]['name']> = {
  'chart-bar': 'chart-bar',
  'cpu-chip': 'cpu-chip',
  'code-bracket': 'code-bracket',
  'map': 'map-pin',
  'globe': 'globe',
  'newspaper': 'newspaper',
};
const iconName = iconMap[icono] ?? 'chart-bar';
---
<BaseLayout title={nombre} description={descripcionCorta}>

  <!-- Header -->
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <a href={u('/carreras')} class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Todas las carreras
      </a>
      <div class="flex items-start gap-4">
        <div class="hidden sm:flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-accent/20 text-accent">
          <Icon name={iconName} class="w-7 h-7" />
        </div>
        <div>
          {nueva && (
            <span class="inline-block rounded-full bg-accent/20 border border-accent/30 px-3 py-0.5 text-xs font-semibold text-accent mb-3">
              Nueva 2026
            </span>
          )}
          <h1 class="text-3xl md:text-4xl font-bold leading-tight">{nombre}</h1>
          <p class="text-slate-300 mt-3 max-w-2xl text-lg">{descripcionCorta}</p>
          <div class="flex flex-wrap gap-4 mt-5 text-sm text-slate-400">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
              </svg>
              {duracion}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25"/>
              </svg>
              {modalidad}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
              </svg>
              Título oficial
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Main content -->
      <div class="lg:col-span-2">
        <div class="prose prose-slate max-w-none prose-headings:font-bold prose-headings:text-slate-900 prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-p:text-slate-600 prose-li:text-slate-600 prose-a:text-accent prose-a:no-underline hover:prose-a:underline">
          <Content />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="flex flex-col gap-5">
        {planPdf ? (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="font-semibold text-slate-900 mb-3">Plan de estudios</h3>
            <a
              href={planPdf}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 rounded-xl bg-accent/10 px-4 py-3 text-sm font-medium text-accent-dark hover:bg-accent/20 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
              </svg>
              Descargar PDF
            </a>
          </div>
        ) : (
          <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-center">
            <svg class="w-8 h-8 text-slate-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
            </svg>
            <p class="text-sm text-slate-400 font-medium">Plan de estudios</p>
            <p class="text-xs text-slate-400 mt-1">Próximamente disponible</p>
          </div>
        )}

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-semibold text-slate-900 mb-4">¿Te interesa esta carrera?</h3>
          <p class="text-sm text-slate-500 mb-4">Consultanos para más información sobre inscripciones, fechas y modalidad.</p>
          <div class="flex flex-col gap-2">
            <a
              href={u('/inscripcion')}
              class="rounded-xl bg-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-light transition-colors text-center"
            >
              Inscribirme
            </a>
            <a
              href={u('/contacto')}
              class="rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:border-accent hover:text-accent transition-colors text-center"
            >
              Consultar
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
