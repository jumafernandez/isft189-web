---
import BaseLayout from '../layouts/BaseLayout.astro';
import { u } from '../lib/url';
---
<BaseLayout
  title="Inscripción"
  description="Información sobre el proceso de inscripción para las tecnicaturas del ISFT N°189 de Luján. Requisitos, documentación y contacto."
>
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent mb-2">Inscripciones 2026</p>
      <h1 class="text-4xl font-bold mb-3">Cómo inscribirse</h1>
      <p class="text-slate-300 max-w-2xl">
        Las inscripciones para el ciclo lectivo 2026 están abiertas. Seguí los pasos a continuación
        para sumarte a una de nuestras tecnicaturas.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Steps -->
      <div class="lg:col-span-2 flex flex-col gap-8">

        <section>
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Pasos para inscribirse</h2>
          <ol class="flex flex-col gap-6">
            {[
              {
                step: '1',
                titulo: 'Elegí tu carrera',
                desc: 'Revisá nuestra oferta de 6 tecnicaturas y elegí la que mejor se adapte a tus intereses y objetivos.',
                link: u('/carreras'),
                linkLabel: 'Ver carreras',
              },
              {
                step: '2',
                titulo: 'Reuní la documentación',
                desc: 'Prepará la documentación requerida: DNI, certificado de estudios secundarios (original o título en trámite) y 2 fotos 4x4.',
              },
              {
                step: '3',
                titulo: 'Completá el formulario de inscripción',
                desc: 'Acercate a la secretaría del instituto o escribinos para recibir el formulario de inscripción.',
                link: u('/contacto'),
                linkLabel: 'Contactarnos',
              },
              {
                step: '4',
                titulo: '¡Listo!',
                desc: 'Una vez procesada tu inscripción, recibirás información sobre el inicio de clases, el campus virtual y los materiales necesarios.',
              },
            ].map(item => (
              <li class="flex gap-4">
                <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white font-bold text-sm">
                  {item.step}
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900">{item.titulo}</h3>
                  <p class="text-sm text-slate-500 mt-1 leading-relaxed">{item.desc}</p>
                  {item.link && (
                    <a href={item.link} class="text-sm font-medium text-accent hover:text-accent-dark transition-colors mt-2 inline-block">
                      {item.linkLabel} →
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Requisitos</h2>
          <ul class="flex flex-col gap-2">
            {[
              'Título secundario completo (o certificado de materias aprobadas si todavía estás cursando el último año)',
              'DNI (original y fotocopia)',
              '2 fotografías 4×4',
              'Certificado de domicilio',
            ].map(req => (
              <li class="flex items-start gap-2 text-slate-700 text-sm">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                {req}
              </li>
            ))}
          </ul>
          <p class="text-xs text-slate-400 mt-4 italic">
            * Los requisitos específicos pueden variar. Consultanos para más información.
          </p>
        </section>

      </div>

      <!-- Sidebar -->
      <aside class="flex flex-col gap-5">
        <div class="rounded-2xl bg-primary text-white p-6 shadow-sm">
          <h3 class="font-semibold mb-4">Contacto para inscripciones</h3>
          <ul class="flex flex-col gap-3 text-sm">
            <li class="flex items-center gap-2 text-slate-300">
              <svg class="w-4 h-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
              </svg>
              (02323) 436549
            </li>
            <li class="flex items-center gap-2 text-slate-300 break-all">
              <svg class="w-4 h-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
              </svg>
              Instituto189info@gmail.com
            </li>
          </ul>
          <a
            href={u('/contacto')}
            class="mt-5 block rounded-xl bg-accent px-4 py-2.5 text-sm font-semibold text-primary hover:bg-accent-light transition-colors text-center"
          >
            Ir al formulario
          </a>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-semibold text-slate-900 mb-2">¿Tenés dudas?</h3>
          <p class="text-sm text-slate-500 mb-4">Seguinos en redes para estar al tanto de novedades y fechas.</p>
          <div class="flex gap-3">
            <a href="https://www.facebook.com/isft189Lujan" target="_blank" rel="noopener noreferrer"
               class="flex-1 rounded-xl border border-slate-200 py-2.5 text-center text-xs font-medium text-slate-600 hover:border-accent hover:text-accent transition-colors">
              Facebook
            </a>
            <a href="https://www.instagram.com/isft189lujan/" target="_blank" rel="noopener noreferrer"
               class="flex-1 rounded-xl border border-slate-200 py-2.5 text-center text-xs font-medium text-slate-600 hover:border-accent hover:text-accent transition-colors">
              Instagram
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
