---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contacto"
  description="Contactá al ISFT N°189 de Luján. Dirección, teléfono, email y formulario de contacto."
>
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <h1 class="text-4xl font-bold mb-3">Contacto</h1>
      <p class="text-slate-300">Escribinos, llamanos o visitanos en la sede del instituto.</p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Contact info -->
      <div class="flex flex-col gap-8">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Datos de contacto</h2>
          <ul class="flex flex-col gap-5">
            <li class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-slate-900">Dirección</p>
                <p class="text-slate-500 text-sm mt-0.5">Hipólito Yrigoyen 1496<br />Luján, Buenos Aires</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-slate-900">Teléfono</p>
                <a href="tel:+5402323436549" class="text-sm text-accent hover:text-accent-dark transition-colors">(02323) 436549</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-slate-900">Email</p>
                <a href="mailto:Instituto189info@gmail.com" class="text-sm text-accent hover:text-accent-dark transition-colors">
                  Instituto189info@gmail.com
                </a>
              </div>
            </li>
          </ul>
        </div>

        <!-- Map placeholder -->
        <div class="rounded-2xl overflow-hidden border border-slate-200 h-64 bg-slate-100 flex items-center justify-center">
          <a
            href="https://maps.google.com/?q=Hipólito+Yrigoyen+1496,+Luján,+Buenos+Aires"
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center gap-2 text-slate-400 hover:text-accent transition-colors"
          >
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            <span class="text-sm font-medium">Ver en Google Maps ↗</span>
          </a>
        </div>
      </div>

      <!-- Form -->
      <div>
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Envianos un mensaje</h2>
        <form
          action="mailto:Instituto189info@gmail.com"
          method="get"
          class="flex flex-col gap-5"
        >
          <div>
            <label for="nombre" class="block text-sm font-medium text-slate-700 mb-1.5">
              Nombre completo
            </label>
            <input
              type="text"
              id="nombre"
              name="name"
              required
              placeholder="Tu nombre"
              class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="from"
              required
              placeholder="tu@email.com"
              class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition"
            />
          </div>
          <div>
            <label for="asunto" class="block text-sm font-medium text-slate-700 mb-1.5">
              Asunto
            </label>
            <input
              type="text"
              id="asunto"
              name="subject"
              placeholder="Consulta sobre inscripción"
              class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition"
            />
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-medium text-slate-700 mb-1.5">
              Mensaje
            </label>
            <textarea
              id="mensaje"
              name="body"
              required
              rows="5"
              placeholder="Escribí tu consulta acá..."
              class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition resize-y"
            ></textarea>
          </div>
          <button
            type="submit"
            class="rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary-light transition-colors"
          >
            Enviar mensaje
          </button>
          <p class="text-xs text-slate-400 text-center">
            Al hacer clic, se abrirá tu cliente de correo con el mensaje listo para enviar.
          </p>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>
