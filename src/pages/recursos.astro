---
import BaseLayout from '../layouts/BaseLayout.astro';
import { u } from '../lib/url';
---
<BaseLayout
  title="Recursos"
  description="Recursos útiles para estudiantes del ISFT N°189: campus virtual Moodle, mesas de examen y boleto especial educativo."
>
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <h1 class="text-4xl font-bold mb-3">Recursos para estudiantes</h1>
      <p class="text-slate-300">Campus virtual, mesas de examen y documentos útiles.</p>
    </div>
  </div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Campus Moodle -->
      <a
        href="http://200.110.187.39/moodle/login/index.php"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-accent hover:shadow-md transition"
      >
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-accent/10 group-hover:text-accent transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-slate-900 group-hover:text-primary transition-colors">
            Campus Virtual — Moodle
          </h2>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">
            Accedé al campus virtual donde encontrarás los materiales de las materias,
            foros, actividades y comunicación con docentes.
          </p>
        </div>
        <span class="text-sm font-medium text-accent mt-auto">Ir al campus ↗</span>
      </a>

      <!-- Mesas de examen -->
      <a
        href={u('/mesas')}
        class="group flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-accent hover:shadow-md transition"
      >
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-accent/10 group-hover:text-accent transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 9v7.5"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-slate-900 group-hover:text-primary transition-colors">
            Mesas de examen
          </h2>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">
            Fechas y cronograma de mesas de examen finales para las distintas materias y tecnicaturas.
          </p>
        </div>
        <span class="text-sm font-medium text-accent mt-auto">Ver fechas →</span>
      </a>

      <!-- Boleto Especial Educativo -->
      <a
        href={u('/planes/boleto-especial-educativo.pdf')}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-accent hover:shadow-md transition"
      >
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-accent/10 group-hover:text-accent transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-slate-900 group-hover:text-primary transition-colors">
            Boleto Especial Educativo
          </h2>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">
            Instructivo para la tramitación del Boleto Especial Educativo para estudiantes
            de nivel superior en la Provincia de Buenos Aires.
          </p>
        </div>
        <span class="text-sm font-medium text-accent mt-auto">Descargar PDF ↓</span>
      </a>

      <!-- Contacto -->
      <a
        href={u('/contacto')}
        class="group flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-accent hover:shadow-md transition"
      >
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-accent/10 group-hover:text-accent transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-slate-900 group-hover:text-primary transition-colors">
            ¿Necesitás ayuda?
          </h2>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">
            Si no encontrás lo que buscás, contactá a la secretaría del instituto.
          </p>
        </div>
        <span class="text-sm font-medium text-accent mt-auto">Ir al contacto →</span>
      </a>
    </div>
  </div>
</BaseLayout>
