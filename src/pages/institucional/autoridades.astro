---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { u } from '../../lib/url';
---
<BaseLayout
  title="Autoridades"
  description="Equipo directivo y de gestión del ISFT N°189 de Luján."
>
  <div class="bg-primary text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <a href={u('/institucional')} class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        La institución
      </a>
      <h1 class="text-4xl font-bold mb-3">Autoridades</h1>
      <p class="text-slate-300">Equipo directivo y de gestión del instituto.</p>
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20 text-center">
    <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-12">
      <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/>
      </svg>
      <h2 class="text-xl font-semibold text-slate-700 mb-2">Información en preparación</h2>
      <p class="text-slate-500 text-sm leading-relaxed max-w-sm mx-auto">
        Próximamente publicaremos el listado del equipo directivo y de gestión del instituto.
        Para consultas, podés comunicarte directamente con nosotros.
      </p>
      <a
        href={u('/contacto')}
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-light transition-colors"
      >
        Contactarnos
      </a>
    </div>
  </div>
</BaseLayout>
